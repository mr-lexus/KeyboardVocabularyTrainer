  "entries": [
    {
      "id": "entry_pb-small-talk_0",
      "word": "How are you doing today?",
      "translation": "Как ваши дела сегодня?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_1",
      "word": "It's nice to meet you.",
      "translation": "Приятно познакомиться.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_2",
      "word": "Where are you from?",
      "translation": "Откуда вы?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_3",
      "word": "What do you do for a living?",
      "translation": "Чем вы зарабатываете на жизнь?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_4",
      "word": "Have a great day!",
      "translation": "Хорошего дня!",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_5",
      "word": "I've heard a lot about you.",
      "translation": "Я много о вас слышал.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_6",
      "word": "Long time no see!",
      "translation": "Давно не виделись!",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_7",
      "word": "What have you been up to lately?",
      "translation": "Чем занимались в последнее время?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_8",
      "word": "Let's catch up sometime.",
      "translation": "Давай как-нибудь пересечемся.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_9",
      "word": "I'm looking forward to it.",
      "translation": "С нетерпением жду этого.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_10",
      "word": "Could you repeat that, please?",
      "translation": "Не могли бы вы повторить, пожалуйста?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_11",
      "word": "I don't quite understand.",
      "translation": "Я не совсем понимаю.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_12",
      "word": "How do you spell that?",
      "translation": "Как это пишется по буквам?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_13",
      "word": "What does this mean?",
      "translation": "Что это значит?",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_14",
      "word": "Thanks for your help.",
      "translation": "Спасибо за вашу помощь.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_15",
      "word": "No problem at all.",
      "translation": "Вообще без проблем.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_16",
      "word": "I appreciate it.",
      "translation": "Я ценю это.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_17",
      "word": "Sorry, I'm late.",
      "translation": "Извините, я опоздал.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_18",
      "word": "Take your time.",
      "translation": "Не торопитесь.",
      "language": "en"
    },
    {
      "id": "entry_pb-small-talk_19",
      "word": "It doesn't matter.",
      "translation": "Это не имеет значения.",
      "language": "en"
    }
  ]
}