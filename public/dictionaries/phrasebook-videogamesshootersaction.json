{
  "id": "phrasebook-videogamesshootersaction",
  "name": "Video Games (Shooters & Action)",
  "description": "Phrasebook for Video Games (Shooters & Action)",
  "entries": [
    {
      "id": "pb_videogamesshootersaction_0_0",
      "word": "I'm out of ammo.",
      "translation": "У меня кончились патроны.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_1",
      "word": "Tom is going to recover.",
      "translation": "Том выздоровеет.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_2",
      "word": "The rifle is loaded.",
      "translation": "Ружьё заряжено.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_3",
      "word": "You can find him at the rifle range.",
      "translation": "Вы найдёте его на стрельбище.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_4",
      "word": "We split up the loot among the three of us.",
      "translation": "Добычу мы поделили на троих.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_5",
      "word": "We split up the loot three ways.",
      "translation": "Добычу мы поделили на троих.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_6",
      "word": "Tom shot Mary with a rifle.",
      "translation": "Том выстрелил в Мэри из винтовки.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_7",
      "word": "Will he recover?",
      "translation": "Он поправится?",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_8",
      "word": "Cover it with a plate.",
      "translation": "Накрой его тарелкой.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_9",
      "word": "Have you ever shot a rifle?",
      "translation": "Ты когда-нибудь стрелял из ружья?",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_10",
      "word": "This cover doesn't fit.",
      "translation": "Это покрытие не подходит.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_11",
      "word": "The thieves split up their loot.",
      "translation": "Воры поделили добычу между собой.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_12",
      "word": "She shot him with a rifle.",
      "translation": "Она застрелила его из ружья.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_13",
      "word": "Cover your ears.",
      "translation": "Прикройте уши.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_14",
      "word": "Tom has a rifle.",
      "translation": "У Тома есть винтовка.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_15",
      "word": "He's cleaning his rifle.",
      "translation": "Он чистит своё ружьё.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_16",
      "word": "Give me a grenade.",
      "translation": "Дайте мне гранату.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_17",
      "word": "Tom won't recover.",
      "translation": "Том не поправится.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_18",
      "word": "A sniper shot the lights out.",
      "translation": "Снайпер потушил все огни.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_19",
      "word": "I can get someone to cover for me.",
      "translation": "Я могу найти кого-нибудь, кто прикроет меня.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_20",
      "word": "Tom bought a rifle.",
      "translation": "Том купил ружьё.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_21",
      "word": "There's no chance that he'll recover.",
      "translation": "Шансов, что он поправится, нет.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_22",
      "word": "Someone stole the manhole cover.",
      "translation": "Кто-то украл крышку люка.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_23",
      "word": "Put down the rifle.",
      "translation": "Опусти винтовку.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_24",
      "word": "Cover that lumber with a tarp.",
      "translation": "Накройте эти доски брезентом.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_25",
      "word": "Tom owns a hunting rifle.",
      "translation": "У Тома есть охотничья винтовка.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_26",
      "word": "Tom knows how to handle a rifle.",
      "translation": "Том умеет обращаться с винтовкой.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_27",
      "word": "Don't try to cover for Tom.",
      "translation": "Не пытайся прикрывать Тома.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_28",
      "word": "Get my rifle.",
      "translation": "Достань моё ружьё.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_29",
      "word": "We hope to cover the deficit.",
      "translation": "Мы надеемся покрыть дефицит.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_30",
      "word": "I'm afraid Tom's not going to recover.",
      "translation": "Боюсь, Том не оправится.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_31",
      "word": "Tom lowered his rifle.",
      "translation": "Том опустил винтовку.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_32",
      "word": "He is a sharp-shooter.",
      "translation": "Он меткий стрелок.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_33",
      "word": "Tom looked through the scope on his rifle.",
      "translation": "Том смотрел через прицел своего ружья.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_34",
      "word": "Will it take long to recover?",
      "translation": "Восстановление займёт много времени?",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_35",
      "word": "Tom helped Mary recover.",
      "translation": "Том помог Мэри выздороветь.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_36",
      "word": "Tom raised his rifle and pointed it at Mary.",
      "translation": "Том поднял винтовку и нацелил её на Мэри.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_37",
      "word": "Tom will recover.",
      "translation": "Том поправится.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_38",
      "word": "We'll cover all the costs.",
      "translation": "Мы покроем все расходы.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_39",
      "word": "Is there any chance that he'll recover?",
      "translation": "Есть ли шанс, что он поправится?",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_40",
      "word": "Cover your eyes.",
      "translation": "Закрой глаза.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_41",
      "word": "We advanced under cover of darkness.",
      "translation": "Мы продвигались под покровом темноты.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_42",
      "word": "Tom put the rifle away.",
      "translation": "Том убрал винтовку.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_43",
      "word": "The sniper picked off his victims one by one.",
      "translation": "Снайпер снимал своих жертв одну за другой.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_44",
      "word": "Cover your legs.",
      "translation": "Прикрой ноги.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_45",
      "word": "I have a grenade.",
      "translation": "У меня есть граната.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_46",
      "word": "Tom had to cover for Mary.",
      "translation": "Тому пришлось подменить Мэри.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_47",
      "word": "What does your insurance cover?",
      "translation": "Что покрывает страховка?",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_48",
      "word": "Tom hoped that Mary would recover.",
      "translation": "Том надеялся, что Мэри поправится.",
      "language": "en"
    },
    {
      "id": "pb_videogamesshootersaction_0_49",
      "word": "The rifle wasn't loaded.",
      "translation": "Винтовка была не заряжена.",
      "language": "en"
    }
  ]
}